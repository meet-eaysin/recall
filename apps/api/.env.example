# System
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
DEV_AUTH_ENABLED=true
INTERNAL_API_SECRET=internal-api-secret

# Database
MONGODB_URI=mongodb://localhost:27017/mindstack

# Services
WORKER_URL=http://localhost:3002
WEB_APP_URL=http://localhost:5273
CORS_ORIGIN=http://localhost:5273

# Cache (upstash | redis)
CACHE_PROVIDER=redis
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Queue (qstash | http)
QUEUE_PROVIDER=qstash
QSTASH_TOKEN=

# AI & Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
OLLAMA_URL=http://localhost:11434
DEFAULT_LLM_PROVIDER_ID=openrouter
DEFAULT_LLM_MODEL_ID=meta-llama/llama-3.3-70b-instruct:free
DEFAULT_LLM_API_KEY=

# Auth & Crypto
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace-with-a-second-long-random-secret
REFRESH_TOKEN_EXPIRES_IN=7d
ENCRYPTION_KEY=replace-with-exactly-32-characters

# Storage (disk | supabase)
STORAGE_PROVIDER=disk
FILE_UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
SUPABASE_URL=
SUPABASE_KEY=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback
