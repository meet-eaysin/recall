# Single template for both environments.
# Copy to `.env.local` for local development.
# Copy values to `.env.production` or your hosting platform for production.

# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
DEV_AUTH_ENABLED=true

# Core services
MONGODB_URI=mongodb://localhost:27017/mindstack

# Cache Provider Selection
# "upstash" = Use Upstash REST API for general caching (fast, serverless friendly)
# "redis" = Use standard Redis TCP for general caching (local dev)
CACHE_PROVIDER=redis

# 1. General Caching (Used ONLY if CACHE_PROVIDER=upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 2. QStash Messaging Queue (replaces BullMQ)
QSTASH_URL=https://qstash.upstash.io/v2/publish
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Auth and crypto
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace-with-a-second-long-random-secret
REFRESH_TOKEN_EXPIRES_IN=7d
ENCRYPTION_KEY=replace-with-exactly-32-characters

# App settings
FILE_UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
WEB_APP_URL=http://localhost:5273
CORS_ORIGIN=http://localhost:5273

# Optional OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback
