# System
NODE_ENV=development
PORT=3002
WORKER_URL=http://localhost:3002
API_INTERNAL_URL=http://localhost:3001/api/v1/internal/worker
INTERNAL_API_SECRET=internal-api-secret

# Database
MONGODB_URI=mongodb://localhost:27017/mindstack

# Cache (upstash | redis)
CACHE_PROVIDER=redis
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Queue (qstash | http)
QUEUE_PROVIDER=qstash
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Email (resend)
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=

# AI & Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
OLLAMA_URL=http://localhost:11434
DEFAULT_LLM_PROVIDER_ID=openrouter
DEFAULT_LLM_MODEL_ID=meta-llama/llama-3.3-70b-instruct:free
DEFAULT_LLM_API_KEY=

# Storage (disk | supabase)
STORAGE_PROVIDER=disk
FILE_UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
SUPABASE_URL=
SUPABASE_KEY=

# Crypto
ENCRYPTION_KEY=your_encryption_key_here_32_chars!
