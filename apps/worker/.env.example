# System
NODE_ENV=development
PORT=3002

# Database
MONGODB_URI=mongodb://localhost:27017/mindstack

# Cache (upstash | redis)
CACHE_PROVIDER=redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Queue (QStash Signing Keys)
QSTASH_URL=https://qstash.upstash.io/v2/publish
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# AI & Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
OLLAMA_URL=http://localhost:11434
DEFAULT_LLM_PROVIDER_ID=openrouter
DEFAULT_LLM_MODEL_ID=google/gemini-2.5-flash-lite-preview-1.5b:free
DEFAULT_LLM_API_KEY=

# Storage
FILE_UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Crypto
ENCRYPTION_KEY=your_encryption_key_here_32_chars!
