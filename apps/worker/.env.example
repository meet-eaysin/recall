NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/mindstack

# Cache Provider Selection
# "upstash" = Use Upstash REST API for general caching (fast, serverless friendly)
# "redis" = Use standard Redis TCP for general caching (local dev)
CACHE_PROVIDER=redis

# 1. General Caching (Used ONLY if CACHE_PROVIDER=upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 2. QStash Messaging Queue (replaces BullMQ)
QSTASH_URL=https://qstash.upstash.io/v2/publish
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# External Services
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
OLLAMA_URL=http://localhost:11434

# App Settings
FILE_UPLOAD_DIR=./uploads
ENCRYPTION_KEY=your_encryption_key_here_32_chars!
MAX_FILE_SIZE_MB=50
