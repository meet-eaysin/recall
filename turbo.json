{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "MONGODB_URI",
    "JWT_SECRET",
    "QDRANT_API_KEY",
    "ENABLE_EXPERIMENTAL_COREPACK",
    "NODE_ENV",
    "NODE_TLS_REJECT_UNAUTHORIZED",
    "PORT",
    "REDIS_URL",
    "QDRANT_URL",
    "OLLAMA_URL",
    "OLLAMA_BASE_URL",
    "JWT_EXPIRES_IN",
    "REFRESH_TOKEN_SECRET",
    "REFRESH_TOKEN_EXPIRES_IN",
    "ENCRYPTION_KEY",
    "FILE_UPLOAD_DIR",
    "MAX_FILE_SIZE_MB",
    "CORS_ORIGIN"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "typecheck": {
      "cache": true,
      "dependsOn": ["^build"]
    },
    "test": {
      "env": ["JEST_WORKER_ID"]
    },
    "test:e2e": {}
  }
}
