{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "NODE_ENV",
    "PORT",
    "HOST",
    "MONGODB_URI",
    "WORKER_URL",
    "API_INTERNAL_URL",
    "WEB_APP_URL",
    "CORS_ORIGIN",
    "CACHE_PROVIDER",
    "REDIS_URL",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "QUEUE_PROVIDER",
    "QSTASH_TOKEN",
    "QSTASH_CURRENT_SIGNING_KEY",
    "QSTASH_NEXT_SIGNING_KEY",
    "QDRANT_URL",
    "QDRANT_API_KEY",
    "OLLAMA_URL",
    "DEFAULT_LLM_PROVIDER_ID",
    "DEFAULT_LLM_MODEL_ID",
    "DEFAULT_LLM_API_KEY",
    "JWT_SECRET",
    "JWT_EXPIRES_IN",
    "REFRESH_TOKEN_SECRET",
    "REFRESH_TOKEN_EXPIRES_IN",
    "ENCRYPTION_KEY",
    "INTERNAL_API_SECRET",
    "FILE_UPLOAD_DIR",
    "MAX_FILE_SIZE_MB",
    "DEV_AUTH_ENABLED",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GOOGLE_CALLBACK_URL",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "GITHUB_CALLBACK_URL",
    "QSTASH_URL",
    "ENABLE_EXPERIMENTAL_COREPACK",
    "EMAIL_PROVIDER",
    "RESEND_API_KEY",
    "EMAIL_FROM",
    "DEFAULT_EMBEDDING_PROVIDER_ID",
    "DEFAULT_EMBEDDING_MODEL_ID",
    "DEFAULT_EMBEDDING_API_KEY",
    "GROQ_API_KEY",
    "GOOGLE_AI_STUDIO_KEY",
    "STORAGE_PROVIDER",
    "FILE_UPLOAD_DIR",
    "MAX_FILE_SIZE_MB",
    "SUPABASE_URL",
    "SUPABASE_KEY"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "typecheck": {
      "cache": true,
      "dependsOn": ["^build"]
    },
    "test": {
      "env": ["JEST_WORKER_ID"]
    },
    "test:e2e": {}
  }
}
