{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "MONGODB_URI",
    "JWT_SECRET",
    "QDRANT_API_KEY",
    "ENABLE_EXPERIMENTAL_COREPACK",
    "NODE_ENV",
    "NODE_TLS_REJECT_UNAUTHORIZED"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {},
    "test": {
      "env": ["JEST_WORKER_ID"]
    },
    "test:e2e": {}
  }
}
